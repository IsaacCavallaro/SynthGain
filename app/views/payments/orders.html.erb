<section class="content-section">
  <div class="app-container narrow-shell">
    <div class="section-header">
      <div>
        <span class="eyebrow">Orders</span>
        <h1>Your purchases</h1>
      </div>
    </div>

    <div class="stack">
      <% @orders.each do |order| %>
        <article class="panel order-card">
          <div>
            <h2><%= order.listing.title %></h2>
            <p>Purchased <%= time_ago_in_words(order.created_at) %> ago</p>
          </div>
          <div class="button-row">
            <% if order.receipt_url.present? %>
              <%= link_to "Receipt", order.receipt_url, class: "btn btn-outline-dark", target: "_blank", rel: "noreferrer" %>
            <% end %>
            <%= link_to "View listing", listing_path(order.listing), class: "btn btn-primary" %>
          </div>
        </article>
      <% end %>

      <% if @orders.empty? %>
        <div class="panel text-center">
          <p>You have not purchased anything yet.</p>
          <%= link_to "Browse the marketplace", buyers_path, class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</section>
