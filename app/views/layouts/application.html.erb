<!DOCTYPE html>
<html>
  <head>
    <title>SynthGain</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="SynthGain is a curated marketplace for vintage synthesizer enthusiasts buying and selling specialist gear.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Fraunces:opsz,wght@9..144,600;9..144,700&display=swap" rel="stylesheet">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
  </head>

  <body class="app-shell">
    <%= render "shared/navbar" %>

    <main class="page-shell">
      <div class="app-container">
        <%= render "shared/flash" %>
      </div>
      <%= yield %>
    </main>
  </body>
</html>
