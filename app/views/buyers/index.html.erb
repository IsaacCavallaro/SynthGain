<section class="content-section">
  <div class="app-container section-header">
    <div>
      <span class="eyebrow">Marketplace</span>
      <h1>Synths for sale</h1>
      <p class="lead">Search for a title, browse by category, and inspect seller profiles before you buy.</p>
    </div>
  </div>

  <div class="app-container panel search-panel">
    <%= search_form_for(@q, url: buyers_path, method: :get, html: { class: "search-form" }) do |f| %>
      <div class="search-form__field search-form__field--wide">
        <%= f.label :title_or_description_cont, "Search listings" %>
        <%= f.search_field :title_or_description_cont, class: "form-control", placeholder: "Prophet, Juno, Minimoog..." %>
      </div>
      <div class="search-form__field">
        <%= f.label :category_id_eq, "Category" %>
        <%= f.select :category_id_eq, @categories.map { |category| [category.title, category.id] }, { include_blank: "All categories" }, class: "form-select" %>
      </div>
      <div class="search-form__actions">
        <%= f.submit "Apply filters", class: "btn btn-primary" %>
        <%= link_to "Reset", buyers_path, class: "btn btn-outline-dark" %>
      </div>
    <% end %>
  </div>

  <div class="app-container listing-grid">
    <% @listings.each do |listing| %>
      <%= render "listings/listing_card", listing: listing %>
    <% end %>
  </div>
</section>
