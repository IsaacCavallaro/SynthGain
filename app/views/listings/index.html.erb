<section class="content-section">
  <div class="app-container section-header">
    <div>
      <span class="eyebrow">Listings</span>
      <h1>Explore the latest gear</h1>
      <p class="lead">A cleaner overview of the newest instruments listed on SynthGain.</p>
    </div>
    <% if user_signed_in? %>
      <%= link_to "Create listing", profile_complete? ? new_listing_path : users_info_new_path(current_user.id), class: "btn btn-primary" %>
    <% end %>
  </div>

  <div class="app-container listing-grid">
    <% @listings.each do |listing| %>
      <%= render "listing_card", listing: listing %>
    <% end %>
  </div>
</section>
