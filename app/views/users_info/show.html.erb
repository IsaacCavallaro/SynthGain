<section class="content-section">
  <div class="app-container profile-shell">
    <div class="panel profile-card">
      <div class="seller-card seller-card--profile">
        <%= profile_avatar(@user_info, css_class: "profile-avatar profile-avatar--large") %>
        <div>
          <span class="eyebrow">Seller profile</span>
          <h1><%= seller_name(@user_info.user) %></h1>
          <p class="lead"><%= seller_location(@user_info) %></p>
        </div>
      </div>

      <div class="profile-grid">
        <div class="profile-stat">
          <small>Country</small>
          <strong><%= @user_info.country %></strong>
        </div>
        <div class="profile-stat">
          <small>City</small>
          <strong><%= @user_info.city %></strong>
        </div>
        <div class="profile-stat">
          <small>Street</small>
          <strong><%= @user_info.street %></strong>
        </div>
        <div class="profile-stat">
          <small>Postcode</small>
          <strong><%= @user_info.postcode %></strong>
        </div>
      </div>
    </div>
  </div>
</section>
