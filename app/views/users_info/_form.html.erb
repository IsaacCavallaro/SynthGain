<%= simple_form_for(@user_info, url: url, method: method, html: { class: "panel form-panel" }) do |user_info_form| %>
  <div class="form-panel__header">
    <span class="eyebrow">Seller profile</span>
    <h1><%= @user_info.persisted? ? "Update profile" : "Create your profile" %></h1>
    <p>Give buyers enough context to trust the person behind the listing.</p>
  </div>

  <div class="form-grid">
    <div class="field">
      <%= user_info_form.label :country, class: "form-label" %>
      <%= user_info_form.text_field :country, class: "form-control", placeholder: "Australia" %>
    </div>

    <div class="field">
      <%= user_info_form.label :city, class: "form-label" %>
      <%= user_info_form.text_field :city, class: "form-control", placeholder: "Brisbane" %>
    </div>

    <div class="field">
      <%= user_info_form.label :street, class: "form-label" %>
      <%= user_info_form.text_field :street, class: "form-control", placeholder: "Paddington" %>
    </div>

    <div class="field">
      <%= user_info_form.label :postcode, class: "form-label" %>
      <%= user_info_form.text_field :postcode, class: "form-control", placeholder: "4064" %>
    </div>
  </div>

  <div class="field">
    <%= user_info_form.label :picture, class: "form-label" %>
    <%= user_info_form.file_field :picture, accepts: "image/png,image/jpg,image/jpeg", class: "form-control" %>
    <small class="form-text text-muted">A clear photo helps buyers trust your listings.</small>
  </div>

  <div class="button-row">
    <%= user_info_form.submit @user_info.persisted? ? "Save profile" : "Create profile", class: "btn btn-primary btn-lg" %>
    <%= link_to "Back", buyers_path, class: "btn btn-outline-dark btn-lg" %>
  </div>
<% end %>
